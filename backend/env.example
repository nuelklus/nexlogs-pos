# Database Configuration

# Local PostgreSQL (Development) - Used when DJANGO_SETTINGS_MODULE=hardware_api.settings.dev
LOCAL_DB_NAME=hardware_ecommerce
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=your_local_postgres_password
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432

# Supabase (Production) - Used when DJANGO_SETTINGS_MODULE=hardware_api.settings.prod
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_DB_NAME=hardware_ecommerce
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_password
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432

# Django Configuration
DJANGO_SECRET_KEY=your-very-secret-key-here-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-app-name.onrender.com,localhost,127.0.0.1

# Email Configuration (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password
DEFAULT_FROM_EMAIL=noreply@hardware-ecommerce.com
ADMIN_EMAIL=admin@hardware-ecommerce.com

# CORS Configuration
DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.onrender.com

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here

# Render-specific
RENDER_EXTERNAL_HOSTNAME=your-app-name.onrender.com
